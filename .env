# =============================================================================
# ProPaths — Production Configuration
# =============================================================================
# Loaded by app.py via python-dotenv on startup. load_dotenv(override=True)
# means values in this file WIN over any pre-existing shell env vars.
#
# `python3 app.py` from the project root is the canonical launch command.
# No IDE or Docker needed. Every knob the code reads is below, explicitly set
# with an inline comment explaining what changes if you flip it. The defaults
# here are the tested "known good" values — do not modify without a reason.
# =============================================================================


# =============================================================================
# Google Cloud (Vertex AI for Gemini LLM)
# =============================================================================
GOOGLE_CLOUD_PROJECT=gen-lang-client-0169793975
GOOGLE_CLOUD_LOCATION=global

# Flash-only model pins. load_dotenv(override=True) in app.py makes these
# values win over stale shell exports, so every normal pipeline role stays on
# gemini-3-flash-preview unless this file is deliberately changed.
GEMINI_MODEL_CORE=gemini-3-flash-preview
GEMINI_MODEL_EVIDENCE=gemini-3-flash-preview
GEMINI_MODEL_ARROW=gemini-3-flash-preview
GEMINI_MODEL_ARROW_FAST=gemini-3-flash-preview
GEMINI_MODEL_FLASH=gemini-3-flash-preview
GEMINI_MODEL_ITERATIVE=gemini-3-flash-preview


# =============================================================================
# Database (PostgreSQL on Railway)
# =============================================================================
# app.py:33 prefers DATABASE_PUBLIC_URL, falls back to DATABASE_URL. Both
# point at the same Railway instance — DATABASE_PUBLIC_URL is the external
# IP (what the app actually connects to), DATABASE_URL is the internal
# proxy (useful if deploying on Railway itself).
#
# app.py also defensively strips a leading `DATABASE_URL=` if Railway's
# "copy as secret" accidentally embeds it — so the clean single-prefix
# form here is safe.
DATABASE_URL=postgresql://postgres:jLFCwZXNLVLdLTnFqJwHAuMZlqEMyRVn@caboose.proxy.rlwy.net:51981/railway
DATABASE_PUBLIC_URL=postgresql://postgres:jLFCwZXNLVLdLTnFqJwHAuMZlqEMyRVn@66.33.22.253:51981/railway


# =============================================================================
# NCBI PubMed (citation verification + fact checking)
# =============================================================================
NCBI_EMAIL=azandi1@uci.edu
NCBI_API_KEY=40d004b643f7ecca12f0f72d0b34ab9ef409


# =============================================================================
# Pipeline mode & request plumbing
# =============================================================================
# iterative (default): chained Flash calls with Google Search grounding.
# modern:              single Deep Research call; do not use for Flash-only runs.
PIPELINE_MODE=iterative

# standard: synchronous calls (default).
# batch:    submit batch jobs (~50% cost, hours of latency — only for bulk).
GEMINI_REQUEST_MODE=standard

# Verbose pipeline logging — prints every step's prompt/response to stderr.
VERBOSE_PIPELINE=true

# Step logger — writes per-step JSON + terminal capture under Logs/<protein>/.
ENABLE_STEP_LOGGING=true

# Delay between iterative discovery rounds. Avoids tripping per-minute RPM.
ITERATIVE_DELAY_SECONDS=1.0

# Chain claim style. 'tailored' is current (hop-specific); 'standalone' was legacy.
CHAIN_CLAIM_STYLE=tailored

# Server-side output truncation. true = silently clamp over-cap requests
# (e.g. 65536-requested → 8192-cap). false hard-failed batch 19 of the
# 2026-05-02 ATXN3 AX phase ("Server cap … is 8192 tokens, requested 65536")
# rather than truncating; with CHAIN_CLAIM_MAX_OUTPUT_TOKENS now matching
# the cap exactly, this is doubly safe — the request and cap agree, and
# the clamp is a defensive net for any caller that still over-requests.
GEMINI_ALLOW_SERVER_OUTPUT_CLAMP=true


# =============================================================================
# Parallelism / concurrency
# =============================================================================
# Main pipeline default batching/concurrency.
PARALLEL_BATCH_SIZE=5
# Flash-only stability: keep concurrent Gemini calls below the point where
# chain-heavy queries start producing 503/UNAVAILABLE bursts.
PARALLEL_MAX_WORKERS=8

# Parallel dispatcher rate-limit tuning (applies to every PARALLEL:*
# phase in runner.py: function_mapping, function_mapping_expansion,
# function_mapping_chain_promoted, ax_claim_generation_explicit,
# az_claim_generation_hidden, citation_verification).
#
# PARALLEL_RATE_LIMIT_GROUP: how many batches fire concurrently before
# the next group is gated on token budget.
PARALLEL_RATE_LIMIT_GROUP=8

# PARALLEL_RATE_LIMIT_PAUSE: optional fixed sleep between groups. Kept
# at 0 because the TPM-aware throttle is adaptive; a blind 10-second
# nap stalled the pipeline even when quota was free. Flip to e.g. 3
# only if the TPM tracker reports budget-clears but you still see 429s.
PARALLEL_RATE_LIMIT_PAUSE=0
GEMINI_HTTP_POOL_MAX_CONNECTIONS=96
GEMINI_HTTP_POOL_MAX_KEEPALIVE=48
GEMINI_HTTP_RETRY_ATTEMPTS=1
GEMINI_HTTP_RETRY_INITIAL_DELAY=0.5
GEMINI_HTTP_RETRY_MAX_DELAY=4
GEMINI_HTTP_RETRY_EXP_BASE=1.6
GEMINI_HTTP_RETRY_JITTER=0.25
FUNCTION_MAPPING_ROLLING_DISPATCH=true
FUNCTION_MAPPING_BATCH_SIZE=4
FUNCTION_MAPPING_MAX_WORKERS=8
FUNCTION_MAPPING_REQUEST_TIMEOUT_MS=120000
FUNCTION_MAPPING_HTTP_RETRY_ATTEMPTS=1
FUNCTION_MAPPING_MAX_RETRIES=1
FUNCTION_MAPPING_FAILED_BATCH_RETRIES=1
FUNCTION_MAPPING_RETRY_BASE_DELAY=2

# GEMINI_TPM_BUDGET: rolling 60-second token ceiling the dispatcher
# enforces across ALL parallel phases in a run. Conservative Tier-1
# paid-preview estimate (600k tokens/min). Raise to 1_500_000 on Tier 2,
# 4_000_000 on Tier 3. Set to 0 to disable (not recommended).
GEMINI_TPM_BUDGET=600000

# CHAIN_CLAIM_BATCH_SIZE: hop pairs packed into one 2ax/2az API call.
# 2026-05-03: dropped 2 → 1.  Even the 2-pair packing was breaching the
# 8192-token Flash output cap on real runs:
#   TDP43 run had 2/16 ax-batches finish_reason=MAX_TOKENS (~12.5%) plus
#   1 batch truncated mid-stream (4 unclosed → split-retry).  The earlier
#   "<5% truncation" estimate was wrong for the new 6-10 sentences /
#   3-5 cascades depth requirements.
# Going to 1 pair/call doubles the absolute call count but eliminates the
# truncation root cause and the recovery+split-retry overhead that was
# costing more (in latency) than just running each pair as its own call.
# CHAIN_CLAIM_MAX_WORKERS=3 (below) keeps wall-clock tolerable.
CHAIN_CLAIM_BATCH_SIZE=1
CHAIN_CLAIM_THINKING_LEVEL=low
# Bumped 0.25 → 0.45 (2026-04-29). At 0.25 the model was anchoring too
# tightly on its highest-probability response and dropping hard hops
# entirely (see [CHAIN AUDIT] missing_chain_link_functions logs in the
# TDP43 run: RNA->STMN2, RNA->CFTR, RNA->PICALM, RNA->GRIA2, UBQLN2->PSMD1).
# 0.45 lets it stretch into harder cases without going off-rails. Still
# well below function-mapping's 1.0 since chain-claim work is constrained
# (one fixed pair per call) rather than exploratory. Drop back to 0.25 if
# truncation rate spikes or claims start sounding inconsistent.
CHAIN_CLAIM_TEMPERATURE=0.45
# 2026-05-03: 8192 → 10000 → 24000.
# The "8192 is the actual server cap" claim was WRONG. Verified via Vertex
# AI docs (docs.cloud.google.com/vertex-ai/generative-ai/docs/models/gemini/3-flash):
# gemini-3-flash-preview real output cap is 65,536 tokens, not 8192. The
# error message we kept seeing — "answer candidate length is too long
# with 8197 tokens, which exceeds the maximum token limit of 8192" — was
# Vertex enforcing OUR request cap, not its own.
#
# REST run at 8192 cap: 27.5% first-pass truncation, 61.5% in depth-expand,
# 1 hard 400 INVALID_ARGUMENT for 8197-token output. The 5 unrecoverable
# hops were all REST-cofactor cases (REST→CREBBP, MAPK1→ERK2, GSK3B→AXIN1,
# GSK3B→BTRC, BTRC→REST) — densely-studied proteins whose PhD-depth output
# easily reaches 10K-15K tokens.
#
# Why 24000 specifically (not 65536 or 12336):
#   - 3× the original 8K baseline → bombproof for any realistic output
#   - Below the threshold where (uncertain) thinking-budget proportionality
#     would matter much: even at the 25%-of-budget assumption that's ~6K
#     thinking + 18K output, both reasonable for chain-claim work.
#   - max_output_tokens is a CEILING, NOT a target. The model emits what
#     the prompt + schema demand. Setting 24K instead of 12K does NOT
#     make the model produce more output — Vertex bills per emitted token.
#   - If empirically we see runs slow (proportional thinking is real) we
#     drop to 16384. If we see lingering truncation on extreme cases we
#     bump to 32768. 24K is the sweet-spot starting value.
CHAIN_CLAIM_MAX_OUTPUT_TOKENS=24000
# AX/AZ starts at 3 rolling workers. If Vertex returns deadline/cancel/timeout
# pressure, runner.py automatically lowers remaining AX/AZ dispatch to
# CHAIN_CLAIM_ADAPTIVE_WORKERS instead of continuing to saturate search calls.
CHAIN_CLAIM_MAX_WORKERS=3
# Bumped 1 → 2 (2026-05-03). Governs depth-expand concurrency at runner.py
# 6385/7411 and recovery-pass concurrency on retry. Was the dominant cost
# of the 2026-05-02 ATXN3 run: 10 depth-expand batches × 30-180s serial =
# ~25 min single-threaded. 2 halves that. Kept at 2 (not 3) so retry
# passes after a real Gemini outage still have a safety brake.
CHAIN_CLAIM_RECOVERY_MAX_WORKERS=2
# Two compact in-call attempts absorb transient 503/504s without letting one
# bad hop monopolize the phase for many minutes.
CHAIN_CLAIM_MAX_RETRIES=2
CHAIN_CLAIM_FAILED_BATCH_RETRIES=1
CHAIN_CLAIM_RETRY_BASE_DELAY=4
PARALLEL_GROUP_HEARTBEAT_SECONDS=30
CHAIN_CLAIM_ROLLING_DISPATCH=true
CHAIN_CLAIM_ADAPTIVE_DISPATCH=true
# Bumped 1 → 3 (2026-05-03). Adaptive throttle floor at runner.py:3363.
# Equal to CHAIN_CLAIM_MAX_WORKERS, so the throttle's `target_workers >
# adaptive_floor` guard at runner.py:3448 is never satisfied — concurrency
# stays at 3 even after a 504. Was 1, which permanently single-threaded
# AX/AZ for 25+ batches once the first 504 fired (2026-05-02 ATXN3).
# Set back to 1 only if Gemini sustains an outage and the in-call retry
# budget (CHAIN_CLAIM_MAX_RETRIES=2) starts saturating.
CHAIN_CLAIM_ADAPTIVE_WORKERS=3
# Local read timeout for chain claims (R2 — raised 150000 → 240000ms).
# Vertex's server-side deadline for gemini-3-flash-preview is ~180s under
# heavy load; the previous 150000ms client timeout was BELOW that, so
# requests the server was about to deliver got killed locally first
# (PERK 2026-04-30 run had 5+ "504 DEADLINE_EXCEEDED" warnings during
# AX, including one batch that exhausted retries and failed entirely).
# 240000ms (4 minutes) gives 60s of slack above the server deadline so a
# retry happens only when the request is genuinely stuck, not just slow.
# If runs still 504 after this, raise to 300000 OR set to 0 (no client
# timeout — rely on the server deadline + adaptive worker reduction at
# CHAIN_CLAIM_RECOVERY_MAX_WORKERS=2 above).
CHAIN_CLAIM_REQUEST_TIMEOUT_MS=240000
CHAIN_CLAIM_HTTP_RETRY_ATTEMPTS=2

# Chain-claim adaptive overrides (R2). Once depth was tightened to PhD-
# level (P2.1: 6+ sentences cellular_process AND effect_description, 3-5
# cascades, 3+ specific_effects, 3+ evidence), per-pair response payloads
# grew enough that thinking_level=low must be loosened on retry to give
# the model room to actually emit deep prose without hitting the
# server-side deadline mid-generation. Bump these together with
# CHAIN_CLAIM_REQUEST_TIMEOUT_MS below — the recovery worker count
# already drops to 2 on 504 pressure (CHAIN_CLAIM_RECOVERY_MAX_WORKERS=2
# above), so adaptive concurrency is already in place.

# CHAIN_CLAIM_REQUEST_MODE: transport for chain-claim generation.
#   standard  = synchronous HTTP (default; honors TPM throttle).
#   batch     = async Gemini Batch API (quota-exempt, ~30s poll/group).
CHAIN_CLAIM_REQUEST_MODE=standard

# Reuse existing PostgreSQL pair claims before spending new 2ax/2az calls.
# STRICT_CHAIN_CLAIM_ZERO_SKIP=false means DB rehydration is allowed even when
# this run entered the chain-claim phase.
CHAIN_CLAIM_DB_REHYDRATE=true
STRICT_CHAIN_CLAIM_ZERO_SKIP=false

# Arrow validator concurrency. Was 20 — lowered to 5 (Session 2026-04-21
# Round 3.1) to stop tripping Vertex per-minute RPM on arrow validation.
VALIDATION_MAX_WORKERS=5

# Evidence validator batching (LLM + NCBI). Keep small to avoid 429s.
VALIDATION_BATCH_SIZE=4
VALIDATION_BATCH_DELAY=0.5

# Citation finder batching (LLM + NCBI PubMed).
CITATION_BATCH_SIZE=4
CITATION_BATCH_DELAY=1.5


# =============================================================================
# Claim caps (UI sliders can override per query; these are defaults)
# =============================================================================
# Max claims written per chain hop. Flash-only chain generation must stay
# compact; prefer 1 claim/hop and allow 2 only for distinct mechanisms.
MAX_CHAIN_CLAIMS_PER_LINK=1

# Max claims per direct interaction.
MAX_CLAIMS_PER_LINK=10

# Max claims surfaced in the visualizer modal per link.
VISUALIZATION_MAX_CLAIMS_PER_LINK=10

# Hard ceiling per interaction row — prevents a pathological (protein_a,
# protein_b) pair from accumulating hundreds of stale claims over re-queries.
MAX_CLAIMS_PER_INTERACTION=30


# =============================================================================
# Content validators — default ON (catch LLM prose/field mismatches)
# =============================================================================
# TRUE  = rewrite arrow / direction / pathway fields in-place at payload-build
#         time when the prose verb contradicts the declared field.
# FALSE = validator silent, bad labels pass through unchanged.
#
# These were flipped back to true (Session 2026-04-20 A1) after being
# accidentally disabled — they're a precision quality gate with very few
# false positives.
ARROW_AUTO_CORRECT=false
DIRECTION_AUTO_CORRECT=false
# P3.2: flipped true → false. The pathway validator at
# services/data_builder.py:909-933 rewrote claim["pathway"] in the
# serialized payload at READ TIME, but the DB row was never updated. So
# every page load triggered the heuristic again, the user saw a
# different pathway than what was actually assigned, and there was no
# visible correction trail. Per the user's "don't let read-time drift
# heuristics silently decide visible science" rule, the validator is
# now report-only by default. The proper fix lives in
# scripts/pathway_v2/quick_assign.py (P3.1) where the chain pathway
# unification pass runs once and PERSISTS its decisions to the DB.
PATHWAY_AUTO_CORRECT=false


# =============================================================================
# Per-stage skip toggles (10 post-processing stages)
# =============================================================================
# false = run the stage (data quality); true = skip (save cost).
# These are DEFAULTS. UI toggles override when the user explicitly sets them;
# the env var wins only when the UI is unset.

# 1. Schema validation (pure, free) — catches payload-shape drift early.
DEFAULT_SKIP_SCHEMA_VALIDATION=false

# 2. Normalize function_context (pure) — eliminates function_context_drift.
SKIP_NORMALIZE_FUNCTION_CONTEXTS=false

# 3. Arrow validation (LLM, critical) — THE primary quality gate. DO NOT SKIP.
DEFAULT_SKIP_ARROW_VALIDATION=false

# 4. Direct link extraction — extracts direct claims from chain-link data
#    (e.g. VCP→UFD1 as DIRECT when the chain assay is direct). DO NOT SKIP.
SKIP_DIRECT_LINK_EXTRACTION=false

# 5. Post-processor PMID lookup — redundant with in-pipeline step2e.
DEFAULT_SKIP_PMID_UPDATE=true

# 6. Citation verification — redundant with in-pipeline step2e.
SKIP_CITATION_VERIFICATION=true

# 7. Evidence fact-checking against PubMed (LLM + NCBI). Expensive; default skip.
DEFAULT_SKIP_FACT_CHECKING=true

# 8. Interaction metadata synthesis (LLM) — enriches interaction-level metadata
#    like support summaries and confidence scores.
DEFAULT_SKIP_INTERACTION_METADATA=false

# 9. Clean function names (pure, cheap) — normalizes names produced by
#    post-processing stages. Flipped true → false (P2.3) per the comment
#    that called it "marginally cleaner names at ~zero cost" — the cost
#    really is zero (pure regex / string normalization) and the names
#    show up in the modal/card-view, so cleaner output is worth running.
DEFAULT_SKIP_CLEAN_NAMES=false

# 10. Metadata finalization (pure) — computes derived interaction_type /
#     function_context fields the frontend reads. DO NOT SKIP.
DEFAULT_SKIP_FINALIZE_METADATA=false


# =============================================================================
# Chain resolution tuning
# =============================================================================
# P3.1 / F1: SELECTIVE chain pathway unification (not the old all-or-nothing
# flag). When true, the unification pass in quick_assign rewrites ONLY
# `chain_id`-tagged claims (chain-derived hop biology) to the chain's chosen
# pathway via tie-break: explicit chain.pathway_name → dominant chain-derived
# hop pathway → first-hop pathway → hierarchy_level. Direct/net claims
# (chain_id=NULL) on the same proteins are NEVER touched and keep their
# independent pathway assignments — exactly the user's "claims that belong
# to the chain story share the chain's pathway, non-chain claims keep their
# own" invariant. Old "false" preserved per-hop diversity but caused chain
# stories to fragment across unrelated pathways under one expanded pathway,
# which is the leak the user kept seeing.
CHAIN_PATHWAY_UNIFY=false

# Skip chain-overlap detection + merge once DB has > N IndirectChain rows.
CHAIN_OVERLAP_SCAN_CAP=5000

# Auto-merge strict prefix/suffix chain-overlap detections at write time.
# Claims/interactions are repointed before subset rows are removed.
ENABLE_CHAIN_MERGE=false

# Tier-2 nested pipeline: spawn a full nested discovery pipeline per missing
# chain link. ~20x cost in the worst case — cap it via the budget below.
# Leave off for normal runs; DB rehydration + Tier 3 cover most chain links.
ENABLE_TIER2_NESTED_PIPELINE=false

# Max Tier-2 nested calls per query (cost cap). Raised 10 → 20 so the
# validator's proportional floor (ceil(0.6 × #indirect_pairs)) has
# headroom. On the ATXN3 run, 10 left 19 pairs downgraded to evidence-
# only Tier 3; with 20 + the proportional floor that drops to ≤ 11.
# ARROW_TIER2_HARD_CAP (default 60) still clamps pathological cases.
ARROW_TIER2_BUDGET=20

# Tier-2 concurrency. Keep low — each nested pipeline is expensive.
ARROW_TIER2_MAX_WORKERS=3

# One-shot chain_context.full_chain backfill on boot. Only needed for
# pre-Arc-8 migration; idempotent after first run.
ENABLE_BACKFILL_AT_STARTUP=false

# DEPTH_CHECK_REDISPATCH: when true, interactors whose flat functions
# still carry `_depth_issues` after the first generation pass get re-
# run through step2a with batch_size=1 and a targeted "expand-the-
# failing-rule" directive (Phase A2). Without this, every recent run
# shipped at 0% PhD-depth pass rate. Cost overhead is ~30-50% extra
# step2a LLM tokens on shallow runs, but it's the only path that
# reliably hits the 6-10 sentences / 3-5 cascades target on Flash.
DEPTH_CHECK_REDISPATCH=true

# SKIP_APP_BOOTSTRAP is intentionally NOT set here. ``app.py`` does
# ``load_dotenv(override=True)`` which would clobber any value set in
# the parent shell — so tools that want to skip bootstrap (Alembic,
# scripts) set the env var BEFORE importing ``app`` and rely on
# ``app.py`` snapshotting it before load_dotenv runs. Defining it as
# an empty string here would defeat the purpose.

# Quick pathway assignment is now the DEFAULT mode (DB-first matching,
# ~2 min per protein, falls back to LLM only on misses). The full LLM
# pathway pipeline produced biologically-wrong parents on the
# 2026-04-29 ULK1 run ("Synaptic Plasticity → Metabolism &
# Bioenergetics") and is much slower. Per-request override is still
# supported via the POST body field `quick_pathway_assignment`.
DEFAULT_QUICK_PATHWAY_ASSIGNMENT=true

# Reroute the LLM's choice of parent pathway when it picks a root that
# doesn't share any topical keyword with the new pathway's name. ON by
# default — set to false to keep the LLM's pick (legacy log-only
# behavior). Keyword-to-root map lives in
# scripts/pathway_v2/quick_assign.py (_ROOT_TOPIC_KEYWORDS); add
# entries when you see real pathways being misrouted.
STRICT_PATHWAY_PARENT_GATE=true


# =============================================================================
# Log rotation (step_logger + verify_pipeline output pruner, runs at app boot)
# =============================================================================
ENABLE_LOG_ROTATION=true
LOG_ROTATION_MAX_AGE_DAYS=30
LOG_ROTATION_KEEP_LATEST=5


# =============================================================================
# Flask
# =============================================================================
# FLASK_DEBUG=true gives auto-reload on .py edits + verbose error pages.
# Required for local dev. NEVER flip this on for a public-facing deploy.
# Also gates SEND_FILE_MAX_AGE_DEFAULT in app.py — when true, static
# files (JS/CSS) are served with max-age=0 so frontend edits propagate
# on a normal refresh (no Cmd+Shift+R needed).
FLASK_DEBUG=true

# FLASK_ENV was deprecated in Flask 2.3+ and is now ignored at runtime.
# Intentionally removed — debug behavior is controlled solely by
# FLASK_DEBUG above and the hardcoded debug=True at app.py:158.
